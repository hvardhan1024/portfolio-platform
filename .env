# Database Configuration
DATABASE_URL=postgresql://<your-rds-username>:<your-rds-password>@<your-rds-endpoint>:5432/<your-db-name>

# Flask Configuration
SECRET_KEY=<your-secret-key>
FLASK_ENV=production
FLASK_DEBUG=False

# AWS Configuration (Use IAM roles or explicit credentials)
AWS_ACCESS_KEY_ID=<your-access-key-id-or-empty-for-iam>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key-or-empty-for-iam>
AWS_REGION=ap-south-1
S3_BUCKET=<your-s3-bucket-name>

# Application Settings
PORT=5000
UPLOAD_MAX_SIZE=16777216
